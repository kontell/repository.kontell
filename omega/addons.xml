<?xml version="1.0" encoding="UTF-8"?>
<addons>
<addon
  id="pvr.kofin"
  version="0.3.0"
  name="Kofin PVR for Jellyfin"
  provider-name="Kontell">
  <requires>
<import addon="kodi.binary.global.main" minversion="2.0.0" version="2.0.2"/>
<import addon="kodi.binary.global.general" minversion="1.0.4" version="1.0.5"/>
<import addon="kodi.binary.global.gui" minversion="5.15.0" version="5.15.0"/>
<import addon="kodi.binary.global.filesystem" minversion="1.1.7" version="1.1.9"/>
<import addon="kodi.binary.global.network" minversion="1.0.0" version="1.0.4"/>
<import addon="kodi.binary.global.tools" minversion="1.0.0" version="1.0.4"/>
<import addon="kodi.binary.instance.pvr" minversion="8.2.0" version="8.3.0"/>
    <import addon="inputstream.ffmpegdirect" minversion="20.0.0"/>
    <import addon="inputstream.adaptive" minversion="20.0.0"/>
  </requires>
  <extension
    point="kodi.pvrclient"
    library_android="pvr.kofin.so"/>
  <extension point="xbmc.service" library="resources/scripts/service.py" start="login"/>
  <extension point="xbmc.addon.metadata">
    <platform>android-aarch64</platform>
    <license>GPL-2.0-or-later</license>
    <assets>
      <icon>icon.png</icon>
    </assets>
    <summary lang="en_GB">Kodi PVR client for Jellyfin Live TV</summary>
    <description lang="en_GB">Native Kodi PVR integration for Jellyfin Live TV. Provides live TV channels, EPG, recordings, and timers from a Jellyfin server with native Kodi UI integration.</description>
      <path>pvr.kofin+android-aarch64/pvr.kofin-0.3.0.zip</path>
  </extension>
</addon>
